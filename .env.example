# ---- Voiceline configuration ----
# Copy to .env and fill in secrets:  cp .env.example .env
# Only OPENAI_API_KEY is required for the default (log) destination.

# --- Server ---
PORT=8080
SERVER_READ_TIMEOUT=15s
SERVER_WRITE_TIMEOUT=15s
SERVER_SHUTDOWN_TIMEOUT=30s

# --- Auth (optional) ---
# If set, requests must send `Authorization: Bearer <token>` or `X-API-Key: <token>`.
# Leave empty to disable auth (open endpoints).
API_KEY=

# --- OpenAI (required) ---
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TRANSCRIPTION_MODEL=whisper-1
OPENAI_ANALYSIS_MODEL=gpt-4o-mini
OPENAI_REQUEST_TIMEOUT=60s
OPENAI_MAX_RETRIES=2

# --- Destination:  log | sheets  (log = zero-setup default) ---
DESTINATION=log

# --- Google Sheets (only when DESTINATION=sheets) ---
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SHEETS_SHEET_NAME=Voicelines
# Host path to the service-account JSON key. Compose mounts this read-only into
# the container automatically (no docker-compose.yml edits needed). Leave empty
# for the default log destination. Used directly as the path when running without
# Docker (make run).
# GOOGLE_APPLICATION_CREDENTIALS=./credentials.json

# --- Pipeline (async worker pool) ---
PIPELINE_WORKERS=4
PIPELINE_QUEUE_SIZE=32
PIPELINE_PROCESSING_TIMEOUT=120s

# --- Upload limits ---
MAX_AUDIO_BYTES=26214400
ALLOWED_AUDIO_TYPES=audio/mpeg,audio/mp4,audio/m4a,audio/x-m4a,audio/wav,audio/x-wav,audio/webm,audio/ogg,audio/flac

# --- Logging:  LOG_LEVEL = debug|info|warn|error,  LOG_FORMAT = json|text ---
LOG_LEVEL=info
LOG_FORMAT=json
